# ---- Database ----
POSTGRES_USER=controlmap
POSTGRES_PASSWORD=controlmap
POSTGRES_DB=controlmap

# ---- Backend / Security ----
# Set AUTH_ENABLED=true to require login (multi-user RBAC mode)
AUTH_ENABLED=false

# Generate a strong secret if enabling auth: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=http://localhost:3000

# Internal system user for audit logs (created on first seed)
ADMIN_EMAIL=system@local
ADMIN_PASSWORD=unused

# Seed NIST controls on startup (required for control mapping)
SEED_ON_STARTUP=true
# Load sample assets/findings/risks (off by default — import your own CSV instead)
SEED_DEMO_DATA=false

# ---- AI (optional). If empty, a deterministic local fallback is used. ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
