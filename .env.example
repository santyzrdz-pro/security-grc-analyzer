# ---- Database ----
POSTGRES_USER=controlmap
POSTGRES_PASSWORD=controlmap
POSTGRES_DB=controlmap

# ---- Backend / Security ----
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---- Bootstrap admin (created on first seed) ----
ADMIN_EMAIL=admin@controlmap.ai
ADMIN_PASSWORD=Admin123!

# Seed demo data on startup (assets, findings, controls, risks)
SEED_ON_STARTUP=true

# ---- AI (optional). If empty, a deterministic local fallback is used. ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
